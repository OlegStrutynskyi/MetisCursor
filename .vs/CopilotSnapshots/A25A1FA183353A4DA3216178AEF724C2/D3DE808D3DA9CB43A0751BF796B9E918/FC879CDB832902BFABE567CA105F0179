        public async Task GetDashboardPage()
        {
            var loginPage = new LoginPage(Page);
            await loginPage.GetLoginPage();
            await loginPage.GetEmailInput().FillAsync(Config.CorrectEmail);
            await loginPage.GetPasswordInput().FillAsync(Config.CorrectPassword);
            await loginPage.ClickLoginBtn();
            await DashboardTitle.WaitForAsync();
            var dashbordPage = new DashboardPage(Page);
        }
