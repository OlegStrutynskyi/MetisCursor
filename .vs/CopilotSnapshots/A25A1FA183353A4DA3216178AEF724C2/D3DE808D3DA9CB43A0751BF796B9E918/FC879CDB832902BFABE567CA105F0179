        //grid
        public async Task<List<string>> GetGridContextNames()
        {
            await GridContextName.First.WaitForAsync();
            var handles = await GridContextName.ElementHandlesAsync();
            var names = new List<string>(handles.Count);
            foreach (var handle in handles)
            {
                var text = (await handle.TextContentAsync()) ?? string.Empty;
                names.Add(text.Trim());
            }
            return names;
        }
        public async Task<List<string>> GetGridContextNames2()
        {
            await GridContextName.First.WaitForAsync();
            var names2 = new List<string>();
            names2 = (List<string>)await GridContextName.AllTextContentsAsync();
            return names2;
        }
        public async Task<int> GetGridTotalNames()
        {
            await GridContextName.First.WaitForAsync();
            var handles = await GridContextName.ElementHandlesAsync();
            return handles.Count;
        }
        
        public async Task<List<string>> GetGridContextNamesAll()
        {
            await GridContextName.First.WaitForAsync();
            var names = new List<string>();
            var nextPageArrow = GetGridPaginatorNextPageArrow();

            while (true)
            {
                // Get context names from the current page
                var pageNames = await GridContextName.AllTextContentsAsync();
                names.AddRange(pageNames);

                // Check if the next page arrow contains "e-disable" class
                var classAttribute = await nextPageArrow.GetAttributeAsync("class");
                if (classAttribute != null && classAttribute.Contains("e-disable"))
                {
                    break; // No more pages, exit loop
                }
                else
                {
                    // Click the next page arrow
                    await nextPageArrow.ClickAsync();
                    Thread.Sleep(500); // Wait for the grid to load the next page
                }
            }

            return names;
        }
        public async Task<int> GetGridContextNamesAllCount()
        {
            int totalCount = 0;
            var nextPageArrow = Page.Locator("//div[contains(@class,'e-next e-icons')]");

            while (true)
            {
                // Get context names count from the current page
                var pageNames = await GridContextName.AllTextContentsAsync();
                totalCount += pageNames.Count;

                // Check if the next page arrow contains "e-disable" class
                var classAttribute = await nextPageArrow.GetAttributeAsync("class");
                if (classAttribute != null && classAttribute.Contains("e-disable"))
                {
                    break; // No more pages, exit loop
                }
                else
                {
                    // Click the next page arrow
                    await nextPageArrow.ClickAsync();
                    Thread.Sleep(500); // Wait for the grid to load the next page
                }
            }

            return totalCount;
        }
