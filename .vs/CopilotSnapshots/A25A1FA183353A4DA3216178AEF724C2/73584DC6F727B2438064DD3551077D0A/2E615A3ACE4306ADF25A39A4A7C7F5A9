        public async Task<string> GetCompanyUUIDFromPostgreSQL(string email)
        {
            var query = $"SELECT \"CompanyId\" FROM public.\"Companies\" WHERE \"SystemAdminEmail\"='{email}'";
            string connectionString = Config.PostgreSqlConnectionStringTest;
            using (NpgsqlConnection connection = new NpgsqlConnection(connectionString))
            {
                NpgsqlCommand command = new NpgsqlCommand(query, connection);
                connection.Open();
                var reader = command.ExecuteReader();
                string companyUUID = string.Empty;
                if (reader.Read())
                {
                    companyUUID = reader["CompanyId"].ToString() ?? string.Empty;
                }
                connection.Close();
                return companyUUID;
            }
        }
